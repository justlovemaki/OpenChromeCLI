{
  "manifest_version": 3,
  "name": "Open Chrome CLI",
  "key": "",
  "version": "1.0",
  "description": "连接浏览器与 AI Agent 的桥梁，支持通过 Agent 调试远程浏览器。",
  "permissions": [
    "nativeMessaging",
    "debugger",
    "tabs",
    "history",
    "downloads",
    "storage",
    "scripting"
  ],
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["icons/cursor-chat.png"]
    }
  ],
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Chrome CLI"
  }
}
